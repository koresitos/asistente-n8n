ebhookId":"90c3278b-d6d0-4771-a45d-19c63fd4c21a"},{"parameters":{"sessionIdType":"customKey","sessionKey":"={{ $json.telefono }}","contextWindowLength":10},"id":"n_memory","name":"Simple Memory","type":"@n8n/n8n-nodes-langchain.memoryBufferWindow","typeVersion":1.3,"position":[2112,528]},{"parameters":{"jsCode":"const items = $input.all();\nreturn items.map(item => {\n  const rawOutput = item.json.output || '';\n  const telefono = $('Config Mochas Place').first().json.telefono;\n  const config = $('Config Mochas Place').first().json.config;\n\n  const completeMatch = rawOutput.match(/\\[ORDER_COMPLETE:(\\{[\\s\\S]*?\\})\\]\\s*$/);\n  const modifyMatch  = rawOutput.match(/\\[ORDER_MODIFY:(\\{[\\s\\S]*?\\})\\]\\s*$/);\n  const cancelMatch  = rawOutput.match(/\\[ORDER_CANCEL:(\\{[\\s\\S]*?\\})\\]\\s*$/);\n\n  let tipoAccion = null;\n  let pedido = null;\n  let notificationText = '';\n  let output = rawOutput;\n\n  const buildNotification = (tipo, p) => {\n    const iconos = { nuevo: '\\u{1F6D2}', modificar: '\\u270F\\uFE0F', cancelar: '\\u274C' };\n    const etiquetas = { nuevo: 'Nuevo pedido', modificar: 'Pedido MODIFICADO', cancelar: 'Pedido CANCELADO' };\n    return `${iconos[tipo]} ${etiquetas[tipo]}!\\n\\nCliente: ${p.nombre || ''}\\nTelefono: ${telefono}\\nProducto: ${p.producto || ''}\\nCantidad: ${p.cantidad || ''}\\nDiseno: ${p.personalizacion || ''}\\nEntrega: ${p.metodo_entrega || ''}\\nNotas: ${p.notas || 'N/A'}`;\n  };\n\n  if (completeMatch) {\n    try {\n      pedido = JSON.parse(completeMatch[1]);\n      pedido.telefono = telefono;\n      tipoAccion = 'nuevo';\n      output = rawOutput.replace(/\\s*\\[ORDER_COMPLETE:[\\s\\S]*?\\]\\s*$/, '').trim();\n      notificationText = buildNotification('nuevo', pedido);\n    } catch(e) {}\n  } else if (modifyMatch) {\n    try {\n      pedido = JSON.parse(modifyMatch[1]);\n      pedido.telefono = telefono;\n      tipoAccion = 'modificar';\n      output = rawOutput.replace(/\\s*\\[ORDER_MODIFY:[\\s\\S]*?\\]\\s*$/, '').trim();\n      notificationText = buildNotification('modificar', pedido);\n    } catch(e) {}\n  } else if (cancelMatch) {\n    try {\n      pedido = JSON.parse(cancelMatch[1]);\n      pedido.telefono = telefono;\n      tipoAccion = 'cancelar';\n      output = rawOutput.replace(/\\s*\\[ORDER_CANCEL:[\\s\\S]*?\\]\\s*$/, '').trim();\n      notificationText = buildNotification('cancelar', pedido);\n    } catch(e) {}\n  }\n\n  return { json: { output, tipoAccion, pedido, notificationText, telefono, config } };\n});"},"id":"n_parse","name":"Parsear respuesta","type":"n8n-nodes-base.code","typeVersion":2,"position":[2064,272]},{"parameters":{"operation":"appendOrUpdate","documentId":{"mode":"id","value":"={{ $json.config.SHEETS_ID }}"},"sheetName":{"mode":"name","value":"={{ $json.config.SHEET_PEDIDOS }}"},"columns":{"mappingMode":"defineBelow","value":{"Fecha":"={{ new Date().toLocaleString('es-MX', {timeZone: 'America/Mexico_City'}) }}","Nombre":"={{ $json.pedido.nombre }}","Telefono":"={{ $json.pedido.telefono }}","Producto":"={{ $json.pedido.producto }}","Cantidad":"={{ $json.pedido.cantidad }}","Personalizacion":"={{ $json.pedido.personalizacion }}","Entrega":"={{ $json.pedido.metodo_entrega }}","Notas":"={{ $json.pedido.notas }}","Status":"Modificado"},"matchingColumns":["Telefono"],"schema":[{"id":"Fecha","displayName":"Fecha","required":false,"defaultMatch":false,"canBeUsedToMatch":true,"display":true,"type":"string","readOnly":false,"removed":false},{"id":"Nombre","displayName":"Nombre","required":false,"defaultMatch":false,"canBeUsedToMatch":true,"display":true,"type":"string","readOnly":false,"removed":false},{"id":"Telefono","displayName":"Telefono","required":false,"defaultMatch":true,"canBeUsedToMatch":true,"display":true,"type":"string","readOnly":false,"removed":false},{"id":"Producto","displayName":"Producto","required":false,"defaultMatch":false,"canBeUsedToMatch":true,"display":true,"type":"string","readOnly":false,"removed":false},{"id":"Cantidad","d